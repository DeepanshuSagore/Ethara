# Database — local dev uses SQLite by default; set Postgres URL in prod (Render).
DATABASE_URL=sqlite:///./ethara.db
# DATABASE_URL=postgresql://user:password@host:5432/ethara

# CORS — comma-separated frontend origins allowed to call the API.
CORS_ORIGINS_RAW=http://localhost:3000

# Groq (AI assistant) — get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
